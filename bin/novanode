#!/usr/bin/env bash

VERSION="1.0.4"
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
NN_USAGE="${SCRIPT_DIR}/nn-usage"

ORANGE=$'\033[38;5;208m'
GREEN=$'\033[38;5;82m'
DIM=$'\033[38;5;245m'
BOLD=$'\033[1m'
RESET=$'\033[0m'

usage() {
  cat << EOF
NovaNode

AI terminal hub for Claude, Codex and Cursor.

Usage:
  novanode
  novanode --help
  novanode --version
  novanode claude
  novanode codex
  novanode cursor

Inside NovaNode:
  /use claude|codex|cursor  Select provider
  /open                     Open selected provider CLI
  /usage                    Refresh usage summary
  /providers                Show providers
  /quit                     Exit
EOF
}

provider_cmd() {
  case "$1" in
    claude) echo "claude" ;;
    codex) echo "codex" ;;
    cursor) echo "cursor" ;;
  esac
}

provider_label() {
  case "$1" in
    claude) echo "Claude Code" ;;
    codex) echo "Codex CLI" ;;
    cursor) echo "Cursor" ;;
  esac
}

exec_provider() {
  local provider="$1"
  local cmd
  cmd="$(provider_cmd "$provider")"
  if ! command -v "$cmd" >/dev/null 2>&1; then
    echo "NovaNode: ${cmd} is not installed or not on PATH." >&2
    return 127
  fi
  if [ "$provider" = "cursor" ]; then
    exec "$cmd" --chat
  fi
  exec "$cmd"
}

send_prompt() {
  local provider="$1"
  local prompt="$2"
  local cmd
  cmd="$(provider_cmd "$provider")"
  if ! command -v "$cmd" >/dev/null 2>&1; then
    echo "NovaNode: ${cmd} is not installed or not on PATH." >&2
    return 127
  fi

  case "$provider" in
    claude|codex)
      "$cmd" "$prompt"
      ;;
    cursor)
      echo "NovaNode: Cursor CLI does not expose a stable terminal chat prompt."
      echo "Opening Cursor Chat instead."
      "$cmd" --chat
      ;;
  esac
}

append_prefixed() {
  local prefix="$1"
  local file="$2"
  if [ ! -s "$file" ]; then
    printf "%s: No response captured.\n" "$prefix"
    return 0
  fi

  while IFS= read -r line; do
    if [ -n "$line" ]; then
      printf "%s: %s\n" "$prefix" "$line"
    fi
  done < "$file"
}

run_prompt() {
  local provider="$1"
  local prompt="$2"
  local transcript_file="$3"
  local cmd output status

  cmd="$(provider_cmd "$provider")"
  if ! command -v "$cmd" >/dev/null 2>&1; then
    printf "NovaNode: %s is not installed or not on PATH.\n" "$cmd" >> "$transcript_file"
    return 127
  fi

  output=$(mktemp "${TMPDIR:-/tmp}/novanode-response.XXXXXX")
  case "$provider" in
    claude)
      "$cmd" --print "$prompt" >"$output" 2>&1
      status=$?
      ;;
    codex)
      "$cmd" exec --color never --output-last-message "$output" "$prompt" >/dev/null 2>>"$output"
      status=$?
      ;;
    cursor)
      printf "NovaNode: Cursor CLI does not expose terminal chat responses. Use /open to launch Cursor Chat.\n" >> "$transcript_file"
      rm -f "$output"
      return 0
      ;;
  esac

  if [ "$status" -ne 0 ]; then
    printf "NovaNode: %s exited with status %s.\n" "$provider" "$status" >> "$transcript_file"
  fi
  append_prefixed "$(provider_label "$provider")" "$output" >> "$transcript_file"
  rm -f "$output"
  return "$status"
}

load_usage() {
  if [ ! -x "$NN_USAGE" ]; then
    echo ""
    return 0
  fi
  AI_USAGE_NO_REFRESH_PROMPT=1 "$NN_USAGE" --summary-tsv </dev/null 2>/dev/null || true
}

render_screen() {
  local active="$1"
  local data="$2"
  local transcript_file="$3"
  local state_line="${4:-}"
  python3 - "$active" "$data" "$transcript_file" "$state_line" << 'PYEOF'
import os, re, shutil, sys, textwrap

active = sys.argv[1]
raw = sys.argv[2]
transcript_file = sys.argv[3]
state_line = sys.argv[4]
size = shutil.get_terminal_size((106, 34))
width = max(80, size.columns)
height = max(24, size.lines)

ORANGE = "\033[38;5;208m"
GREEN = "\033[38;5;82m"
DIM = "\033[38;5;245m"
BOLD = "\033[1m"
RESET = "\033[0m"

providers = []

def fmt_pct(value):
    if value in ("", "n/a", "stale"):
        return value or "n/a"
    return f"{value}%"

def strip_ansi(text):
    return re.sub(r"\033\[[0-9;]*m", "", text)

def fit(text, limit):
    plain = strip_ansi(text)
    if len(plain) <= limit:
        return text + " " * (limit - len(plain))
    out = []
    visible = 0
    i = 0
    while i < len(text) and visible < limit - 1:
        if text[i] == "\033":
            end = text.find("m", i)
            if end == -1:
                break
            out.append(text[i:end + 1])
            i = end + 1
            continue
        out.append(text[i])
        visible += 1
        i += 1
    out.append("…")
    out.append(RESET)
    return "".join(out)

def pct_number(value):
    try:
        return float(str(value).replace("%", "").strip())
    except Exception:
        return None

def mini_bar(left, used, width=18):
    basis = pct_number(left)
    if basis is None:
        basis = 100 - pct_number(used) if pct_number(used) is not None else None
    if basis is None:
        return f"{DIM}{'░' * width}{RESET}"
    fill = round(max(0, min(basis, 100)) / 100 * width)
    return f"{GREEN}{'█' * fill}{DIM}{'░' * (width - fill)}{RESET}"

def box_top(title, w):
    label = f" {title} "
    return f"{ORANGE}╭─{label}{'─' * max(0, w - len(label) - 3)}╮{RESET}"

def box_mid(text, w):
    return f"{ORANGE}│{RESET} {fit(text, w - 4)} {ORANGE}│{RESET}"

def box_bottom(w):
    return f"{ORANGE}╰{'─' * (w - 2)}╯{RESET}"

def hline(w):
    return f"{DIM}{'─' * w}{RESET}"

for line in raw.splitlines():
    cols = line.split("\t")
    if len(cols) < 11:
        continue
    key, command, version, p1, used1, left1, reset1, p2, used2, left2, reset2 = cols[:11]
    name = {"claude": "Claude Code", "codex": "Codex CLI", "cursor": "Cursor"}.get(key, key)
    providers.append({
        "key": key,
        "command": command,
        "name": name,
        "version": f"v{version}" if version != "n/a" else "not detected",
        "p1": p1,
        "used1": used1,
        "left1": left1,
        "reset1": reset1,
        "p2": p2,
        "used2": used2,
        "left2": left2,
        "reset2": reset2,
    })

messages = []
try:
    with open(transcript_file) as fh:
        messages = [line.rstrip("\n") for line in fh if line.strip()]
except Exception:
    pass

active_name = next((p["name"] for p in providers if p["key"] == active), active.title())

def provider_summary(provider):
    if not provider:
        return "usage unavailable"
    primary = f"{provider['p1']} {fmt_pct(provider['left1'])} left"
    secondary = f"{provider['p2']} {fmt_pct(provider['left2'])} left"
    return f"{provider['name']} {provider['version']} · {primary} · {secondary}"

def compact_provider(provider):
    if not provider:
        return "usage unavailable"
    selected = provider["key"] == active
    tone = GREEN if selected else DIM
    mark = "●" if selected else "○"
    return (
        f"{tone}{mark} {provider['key']} {provider['version']} "
        f"{provider['p1']}:{fmt_pct(provider['left1'])} "
        f"{provider['p2']}:{fmt_pct(provider['left2'])}{RESET}"
    )

active_provider = next((p for p in providers if p["key"] == active), None)
chat_h = max(6, height - 11)
chat_lines = []
if messages:
    for msg in messages:
        wrapped = textwrap.wrap(strip_ansi(msg), max(32, width - 6)) or [""]
        for item in wrapped:
            if msg.startswith("You:"):
                chat_lines.append(f"{GREEN}{item}{RESET}")
            elif msg.startswith("NovaNode:"):
                chat_lines.append(f"{ORANGE}{item}{RESET}")
            else:
                chat_lines.append(f"{DIM}{item}{RESET}")
else:
    chat_lines = []

print("\033[3J\033[H\033[2J", end="")
print(box_top(f"NovaNode · {active_name}", width))
if state_line:
    print(box_mid(f"{ORANGE}{state_line}{RESET}", width))
else:
    print(box_mid(f"{BOLD}{GREEN}Welcome back. Chat stays here; provider CLIs run under the hood.{RESET}", width))
print(box_mid(f"{DIM}/use claude · /use codex · /use cursor · /open · /usage · /quit{RESET}", width))
print(box_bottom(width))
print()

visible_chat = chat_lines[-chat_h:]
top_pad = 0 if visible_chat else max(0, chat_h - 1)
for _ in range(top_pad):
    print()
if visible_chat:
    for line in visible_chat:
        print("  " + fit(line, width - 4))
    for _ in range(max(0, chat_h - len(visible_chat))):
        print()
else:
    for _ in range(max(0, chat_h - top_pad)):
        print()

print(hline(width))
if providers:
    status = "  ".join(compact_provider(p) for p in providers)
else:
    status = f"{DIM}usage unavailable{RESET}"
print(fit(status, width))
print(hline(width))
PYEOF
}

case "${1:-}" in
  -h|--help)
    usage
    exit 0
    ;;
  -v|--version)
    echo "$VERSION"
    exit 0
    ;;
  claude|codex|cursor)
    exec_provider "$1"
    ;;
  "")
    ;;
  *)
    echo "Unknown option: $1" >&2
    echo "Run 'novanode --help' for usage." >&2
    exit 2
    ;;
esac

active_provider="claude"
usage_data="$(load_usage)"
TRANSCRIPT_FILE=$(mktemp "${TMPDIR:-/tmp}/novanode-chat.XXXXXX")
trap 'rm -f "$TRANSCRIPT_FILE" 2>/dev/null' EXIT

render_screen "$active_provider" "$usage_data" "$TRANSCRIPT_FILE"

while true; do
  printf "%s%s%s › " "$GREEN" "$active_provider" "$RESET"
  IFS= read -r input || break

  case "$input" in
    "")
      continue
      ;;
    /q|/quit|exit)
      break
      ;;
    /h|/help)
      printf "NovaNode: opened help for commands.\n" >> "$TRANSCRIPT_FILE"
      usage
      ;;
    /providers)
      render_screen "$active_provider" "$usage_data" "$TRANSCRIPT_FILE"
      ;;
    /usage)
      usage_data="$(load_usage)"
      render_screen "$active_provider" "$usage_data" "$TRANSCRIPT_FILE"
      ;;
    /open)
      printf "NovaNode: opening native %s interface.\n" "$active_provider" >> "$TRANSCRIPT_FILE"
      exec_provider "$active_provider"
      ;;
    /use\ *)
      next="${input#/use }"
      case "$next" in
        claude|codex|cursor)
          active_provider="$next"
          render_screen "$active_provider" "$usage_data" "$TRANSCRIPT_FILE"
          ;;
        *)
          printf "NovaNode: invalid provider '%s'.\n" "$next" >> "$TRANSCRIPT_FILE"
          echo "Choose claude, codex or cursor."
          ;;
      esac
      ;;
    /*)
      printf "NovaNode: unknown command '%s'.\n" "$input" >> "$TRANSCRIPT_FILE"
      echo "Unknown command. Run /help."
      ;;
    *)
      printf "You: [%s] %s\n" "$active_provider" "$input" >> "$TRANSCRIPT_FILE"
      render_screen "$active_provider" "$usage_data" "$TRANSCRIPT_FILE" "NovaNode: $active_provider is thinking..."
      run_prompt "$active_provider" "$input" "$TRANSCRIPT_FILE"
      usage_data="$(load_usage)"
      render_screen "$active_provider" "$usage_data" "$TRANSCRIPT_FILE"
      ;;
  esac
done
